{
  "name": "pdfcrop-web",
  "version": "0.1.0",
  "description": "WebAssembly-powered PDF cropping application",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npm run wasm:dev && vite",
    "build": "npm run wasm:build && tsc && vite build",
    "desktop:dev": "cargo tauri dev",
    "desktop:build": "cargo tauri build",
    "preview": "vite preview",
    "wasm": "npm run wasm:build",
    "wasm:dev": "wasm-pack build --target web --dev --out-dir pkg",
    "wasm:build": "wasm-pack build --target web --release --out-dir pkg",
    "clean": "node -e \"const fs=require('node:fs'); ['dist','pkg','node_modules'].forEach((path)=>fs.rmSync(path,{recursive:true,force:true}));\"",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.47",
    "prettier": "^3.6.2",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vite-plugin-top-level-await": "^1.4.4",
    "vite-plugin-wasm": "^3.3.0"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-dialog": "^2.7.0",
    "@tauri-apps/plugin-fs": "^2.5.0",
    "pdfjs-dist": "^4.0.379"
  },
  "keywords": [
    "pdf",
    "crop",
    "wasm",
    "webassembly",
    "rust",
    "typescript"
  ],
  "author": "pdfcrop contributors",
  "license": "MIT OR Apache-2.0"
}
