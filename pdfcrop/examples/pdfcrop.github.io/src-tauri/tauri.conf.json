{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PDFCrop",
  "version": "0.1.0",
  "identifier": "io.github.pdfcrop.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://127.0.0.1:8080",
    "beforeDevCommand": "npm.cmd run dev",
    "beforeBuildCommand": "npm.cmd run build"
  },
  "app": {
    "windows": [
      {
        "title": "PDFCrop",
        "width": 1440,
        "height": 960,
        "minWidth": 1100,
        "minHeight": 760,
        "dragDropEnabled": false,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
